# ─── Motiv environment variables ────────────────────────────────────────────
# Copy to .env.local and fill in. .env.local is gitignored. NEXT_PUBLIC_* values
# are exposed to the browser — never put secrets in a NEXT_PUBLIC_ var.

# ─── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, bypasses RLS — keep secret

# ─── App (required) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=                # live domain; must match Capacitor server.url + Supabase auth URLs
NEXT_PUBLIC_ADMIN_EMAILS=           # DEPRECATED — no longer read by code; system_admin is a DB role now

# ─── Web push (optional — push no-ops if unset) ──────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=                      # e.g. mailto:ops@yourdomain.co.za

# ─── WhatsApp AI intake (optional) ───────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=              # your chosen webhook verify string
WHATSAPP_APP_SECRET=               # Meta App Secret — REQUIRED to verify x-hub-signature-256 in production
GROQ_API_KEY=                      # Groq (OpenAI-compatible) — Whisper + LLaMA

# ─── Cron auth (optional) ────────────────────────────────────────────────────
CRON_SECRET=                       # Bearer secret Vercel Cron sends; falls back to executive-role auth if unset

# ─── Platform owner (optional; SEC-014 / decision D5) ────────────────────────
# app_settings/branding is GLOBAL (one row). Set this to the platform owner's
# user id to restrict branding/customization writes to that one account (so a
# future per-company system_admin can't overwrite everyone's branding). Unset =
# any system_admin may write (current single-tenant default; no lockout).
PLATFORM_OWNER_USER_ID=

# ─── CAPTCHA — Cloudflare Turnstile (optional; auth works normally if unset) ──
# Signup/login/supplier-onboard CAPTCHA (OPS-003). Set BOTH keys together AND
# enable CAPTCHA in Supabase (Authentication → Attack Protection) with the same
# secret — otherwise Supabase rejects auth calls that carry no token. Get keys at
# dash.cloudflare.com → Turnstile (free). Unset = no CAPTCHA (widget hidden,
# server verify no-ops), so nothing breaks before you configure it.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=    # public site key (rendered in the browser widget)
TURNSTILE_SECRET_KEY=             # server secret (used by /api/supplier/onboard siteverify + Supabase)

# ─── Transactional email — Resend (optional; email no-ops if unset) ──────────
RESEND_API_KEY=                    # server-only; sends invites/onboarding (lib/email.ts)
EMAIL_FROM=                        # verified sender, e.g. Motiv <noreply@yourdomain.co.za>

# ─── Observability — Sentry (optional; no-ops if unset) ──────────────────────
# Two tokens because Sentry ORG auth tokens (`sntrys_`) only carry `org:ci`
# (source-map upload) and CANNOT read issues:
#   • SENTRY_AUTH_TOKEN  → build-time source-map upload (an ORG auth token is fine)
#   • SENTRY_API_TOKEN   → /admin/sentry dashboard READS (needs project:read +
#     event:read → use a User Auth Token or an Internal Integration token).
# If SENTRY_API_TOKEN is unset the dashboard falls back to SENTRY_AUTH_TOKEN.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                  # source-map upload at build time (org auth token / org:ci is enough)
SENTRY_API_TOKEN=                  # /admin/sentry reads — User Auth Token or Internal Integration (scopes: project:read, event:read)
SENTRY_ORG=                        # org SLUG (not numeric id), from the Sentry URL
SENTRY_PROJECT=                    # project SLUG (not numeric id)
SENTRY_BASE_URL=                   # optional; auto-derived from the DSN region (e.g. https://de.sentry.io for EU). Set only to force it.

# ─── Distributed rate limiting — Upstash Redis (optional) ────────────────────
# Without these the limiter falls back to in-memory (per-instance, not global).
# Also surfaced live in the admin infra dashboard (/admin/upstash).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Platform-admin infra dashboard — Vercel API (optional) ──────────────────
# Powers /admin/vercel (deployments, build status, domains). Create a token at
# vercel.com → Account Settings → Tokens. VERCEL_TEAM_ID only if the project
# lives under a team. Traffic/bandwidth analytics are NOT in the Hobby API.
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=                 # from Vercel → Project → Settings → General
VERCEL_TEAM_ID=                    # optional; only for team-owned projects

# ─── Uploads (optional) ──────────────────────────────────────────────────────
# Cumulative per-user storage cap across all buckets, in bytes (B5 abuse guard).
# Enforced in POST /api/uploads via reserve_upload_quota(). Default 500 MB.
MAX_USER_UPLOAD_BYTES=524288000

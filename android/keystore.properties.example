# Copy this file to "keystore.properties" (same folder) and fill in real values.
# keystore.properties is gitignored — never commit it, and back up the keystore
# file itself somewhere safe. If you lose this key you can NEVER ship an in-place
# update again (Android will force users to uninstall + reinstall).

storeFile=../../motiv-release.keystore
storePassword=CHANGE_ME
keyAlias=motiv
keyPassword=CHANGE_ME
